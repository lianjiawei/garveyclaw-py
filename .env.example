# WeClaw configuration template
# Copy this file to .env, or run: weclaw setup
#
# New-user path:
# 1. Configure one model provider first.
# 2. Test locally with: weclaw-tui
# 3. Add Telegram / Feishu only when you want a bot channel.

# =============================================================================
# 1. Model provider
# =============================================================================
# This selects the API protocol group, not a fixed vendor.
#
# openai:
#   OpenAI-compatible chat/completions providers.
#   Examples: OpenAI, DeepSeek, Qwen, SiliconFlow, compatible gateways.
#
# claude:
#   Anthropic/Claude-compatible providers.
#   Examples: Anthropic, Claude-compatible gateways.
#
# You only need one group to start. Later you can add more with:
# weclaw model add --protocol openai --name deepseek --api-key xxx --base-url https://.../v1 --model deepseek-chat
AGENT_ROUTE=openai
AGENT_PROVIDER=openai
# Mirrors the currently active model profile.
# `weclaw setup`, `weclaw model add`, and `/model use` keep this in sync.
MODEL_PROFILE_NAME=openai-default

# OpenAI-compatible provider.
# Official OpenAI can leave OPENAI_BASE_URL empty.
# Third-party compatible providers usually require a base URL, often ending in /v1.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
# auto disables provider-specific thinking output for known reasoning models such as Qwen.
# Set to 0 if your OpenAI-compatible provider rejects or does not need this option.
OPENAI_CHAT_DISABLE_REASONING=auto
OPENAI_CHAT_TIMEOUT_SECONDS=180
OPENAI_TOOL_CALL_MAX_ROUNDS=6

# Anthropic-compatible provider.
# Official Anthropic can leave ANTHROPIC_BASE_URL empty.
# Third-party compatible gateways should provide their endpoint here.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# Optional Claude Code / Anthropic-compatible model aliases.
# Leave empty unless your gateway documents these names.
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
CLAUDE_CODE_SUBAGENT_MODEL=
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK=1
CLAUDE_CODE_EFFORT_LEVEL=medium

# =============================================================================
# 2. Local runtime
# =============================================================================
WORKSPACE_DIR=./workspace
UPLOAD_MAX_FILE_SIZE_MB=10
TUI_OUTPUT_DIR=./workspace/outputs/tui
WECLAW_TUI_COLOR_MODE=auto
SHOW_TOOL_TRACE=0
SESSION_TIMEOUT_SECONDS=86400

# Dashboard is safe to keep local by default.
# Use 0.0.0.0 only when you understand the network exposure.
WECLAW_DASHBOARD_HOST=127.0.0.1
WECLAW_DASHBOARD_PORT=8765

# =============================================================================
# 3. Optional bot channels
# =============================================================================
# Leave these empty if you only use weclaw-tui or dashboard-only mode.

# Telegram bot channel.
TELEGRAM_BOT_TOKEN=
OWNER_ID=
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=30
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_BOOTSTRAP_RETRIES=5
TELEGRAM_RESTART_DELAY_SECONDS=10
TELEGRAM_API_RETRIES=2
TELEGRAM_API_RETRY_DELAY_SECONDS=1.5

# Feishu bot channel.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ALLOWED_OPEN_IDS=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_SESSION_SCOPE_PREFIX=feishu
FEISHU_REPLY_PROCESSING_MESSAGE=1
FEISHU_RESTART_DELAY_SECONDS=10
FEISHU_API_RETRIES=2
FEISHU_API_RETRY_DELAY_SECONDS=1.5

# Personal Weixin channel, adapted from HermesAgent's Tencent iLink API approach.
# Requires an iLink bot account id and token. Direct messages are open by default;
# set WEIXIN_DM_POLICY=allowlist and WEIXIN_ALLOWED_USERS=user1,user2 to restrict.
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
WEIXIN_DM_POLICY=open
WEIXIN_ALLOWED_USERS=
WEIXIN_GROUP_POLICY=disabled
WEIXIN_GROUP_ALLOWED_USERS=
WEIXIN_LONG_POLL_TIMEOUT_MS=35000
WEIXIN_RESTART_DELAY_SECONDS=10
WEIXIN_SEND_CHUNK_DELAY_SECONDS=1.5
WEIXIN_SEND_CHUNK_RETRIES=4
WEIXIN_SEND_CHUNK_RETRY_DELAY_SECONDS=1.0

# You can configure channels later without rerunning the full setup:
# weclaw channel setup telegram
# weclaw channel setup feishu
# Weixin can be configured with browser QR login: `weclaw channel setup weixin`.
# weclaw channel setup none

# =============================================================================
# 4. Optional tools
# =============================================================================
# Web search.
# Tavily is preferred when configured.
# If left empty, web_search falls back to a lightweight default search with limited quality/freshness/rate limits.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

# Limit OpenAI-compatible tool names with comma-separated values.
# Leave empty to allow all available tools.
OPENAI_ALLOWED_TOOLS=

# Image generation/editing through an OpenAI-compatible images API.
# Leave empty unless you need image tools.
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=
OPENAI_IMAGE_GENERATE_PATH=/images/generations
OPENAI_IMAGE_EDIT_PATH=/images/edits
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_INCLUDE_OPTIONAL_PARAMS=1
OPENAI_IMAGE_TIMEOUT_SECONDS=120

# Local speech-to-text. WeClaw ships with the default Vosk model at:
#   ./models/asr/vosk-model-small-cn-0.22
ASR_PROVIDER=vosk
ASR_MODELS_DIR=./models/asr
VOSK_MODEL_DIR=./models/asr/vosk-model-small-cn-0.22

# =============================================================================
# 5. Advanced runtime behavior
# =============================================================================
SCHEDULER_INTERVAL_SECONDS=5
CAPABILITY_WATCHER_ENABLED=1
CAPABILITY_WATCHER_INTERVAL_SECONDS=1.0
DECISION_INTERPRETER_MODE=auto
DECISION_INTERPRETER_TIMEOUT_SECONDS=20
DECISION_INTERPRETER_MAX_PROMPT_CHARS=2000
MEMORY_CANDIDATE_AUTO_PROMOTE_SECONDS=86400
CONVERSATION_RETENTION_DAYS=30
MEMORY_ARCHIVE_AFTER_DAYS=30

# Multi-agent / cluster features are experimental. Keep disabled by default.
AGENT_CLUSTER_ENABLED=0
AGENT_CLUSTER_REVIEW_ENABLED=1
AGENT_CLUSTER_ORCHESTRATOR_ENABLED=0
AGENT_CLUSTER_DYNAMIC_PLANNER_ENABLED=0
AGENT_CLUSTER_MAX_EVENTS=40
# AGENT_DEFINITIONS_DIR=./capabilities/agents
